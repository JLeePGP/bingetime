# Copy to .env and fill in. Never commit the real .env.

# Postgres connection (SQLAlchemy + psycopg 3 driver).
# From Railway: enable Public Networking, copy the PUBLIC DATABASE_URL, then
# change the prefix from "postgresql://" to "postgresql+psycopg://".
# Example (Railway): postgresql+psycopg://postgres:PASS@HOST.proxy.rlwy.net:PORT/railway
# Example (local):   postgresql+psycopg://bingetime:bingetime@localhost:5432/bingetime
DATABASE_URL=postgresql+psycopg://bingetime:bingetime@localhost:5432/bingetime

# TMDB API — https://www.themoviedb.org/settings/api
# Accepts either a v3 API key or a v4 read-access (Bearer) token.
# Enrichment (seasons/episodes/runtime/poster) is skipped if this is unset.
# Swappable at any time (free -> commercial license) with no code change.
TMDB_API_KEY=

# App
APP_NAME=BingeTime
# Used to sign session cookies — set a long random value before deploy.
SECRET_KEY=change-me-before-deploy
DEBUG=true

# Comma-separated emails allowed into the story-moderation queue (/account/moderation).
ADMIN_EMAILS=
